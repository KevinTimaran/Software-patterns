/**
 * Clase que representa una computadora. 
 * Utiliza el concepto de "encapsulamiento" al mantener sus atributos privados.
 */
class Computer {
    // Atributos privados: Solo se pueden modificar o leer a través de métodos de la clase
    private String cpu;      // Almacena el modelo del procesador
    private String memory;   // Almacena la cantidad de memoria RAM
    private String storage;  // Almacena la capacidad del disco duro/SSD
    private String gpu;      // Almacena el modelo de la tarjeta gráfica

    // --- MÉTODOS SETTERS ---
    // Estos métodos permiten asignar valores a los atributos privados desde fuera de la clase.

    // Asigna el valor al procesador
    public void setCpu(String cpu) {
        this.cpu = cpu; // "this.cpu" se refiere al atributo de la clase, "cpu" al parámetro recibido
    }

    // Asigna el valor a la memoria
    public void setMemory(String memory) {
        this.memory = memory;
    }

    // Asigna el valor al almacenamiento
    public void setStorage(String storage) {
        this.storage = storage;
    }

    // Asigna el valor a la tarjeta gráfica
    public void setGpu(String gpu) {
        this.gpu = gpu;
    }

    /**
     * Método para mostrar la configuración de la computadora en la consola.
     * Concatena todos los atributos en una sola cadena de texto.
     */
    public void showComputer() {
        // Imprime en pantalla los valores actuales de la instancia
        System.out.println("Computer with CPU: " + cpu + 
                           ", Memory: " + memory + 
                           ", Storage: " + storage + 
                           ", GPU: " + gpu);
    }
}
//----------------------------------------------------------------------------------------------------------------------
// Clase que controla el proceso de construcción
//----------------------------------------------------------------------------------------------------------------------
class ComputerDirector {
    // Referencia a la interfaz del constructor
    private ComputerBuilder computerBuilder;

    // El constructor recibe un builder específico (ej: Gamer, Oficina, etc.)
    public ComputerDirector(ComputerBuilder computerBuilder) {
        this.computerBuilder = computerBuilder;
    }

    // Método que ejecuta los pasos de construcción en orden
    public void buildComputer() {
        computerBuilder.buildCpu();     // Paso 1: CPU
        computerBuilder.buildMemory();  // Paso 2: Memoria
        computerBuilder.buildStorage(); // Paso 3: Almacenamiento
        computerBuilder.buildGpu();     // Paso 4: GPU
    }
}

public class Main {
    public static void main(String[] args) {
        // 1. Elegimos qué tipo de computadora queremos (el Builder)
        ComputerBuilder gamerBuilder = new GamingComputerBuilder();
        
        // 2. Se lo damos al director
        ComputerDirector director = new ComputerDirector(gamerBuilder);
        
        // 3. El director coordina la construcción
        director.buildComputer();
        
        // 4. Obtenemos el producto final
        Computer myPC = gamerBuilder.getComputer();
        myPC.showComputer();
    }
}